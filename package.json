{
  "name": "agentic-qa-demo",
  "version": "1.0.0",
  "description": "Demo: Claude Code Agent Development Kit layers applied to a banking BDD test framework",
  "scripts": {
    "test:smoke": "wdio run wdio.conf.js --cucumberOpts.tags '@smoke'",
    "test:regression": "wdio run wdio.conf.js --cucumberOpts.tags '@regression'",
    "test:perf": "node perf-test.js",
    "test:stress": "node perf-stress-test.js",
    "test:a11y": "node a11y-test.js",
    "test:api": "node api-test.js",
    "test:bstack:smoke": "wdio run wdio.browserstack.conf.js --cucumberOpts.tags '@smoke'",
    "test:bstack:regression": "wdio run wdio.browserstack.conf.js --cucumberOpts.tags '@regression'",
    "test:bstack": "wdio run wdio.browserstack.conf.js",
    "test:compat": "wdio run wdio.compatibility.conf.js",
    "test:compat:full": "wdio run wdio.compatibility.conf.js --cucumberOpts.tags ''",
    "test:all": "node run-all-tests.js",
    "lint": "eslint features/ pageobjects/",
    "wdio": "wdio run ./wdio.conf.js",
    "report:view": "node allure-report-viewer.js",
    "test:smoke:report": "npm run test:smoke && npm run report:view",
    "test:regression:report": "npm run test:regression && npm run report:view"
  },
  "devDependencies": {
    "@axe-core/webdriverio": "^4.8.12",
    "@wdio/allure-reporter": "^9.29.1",
    "@wdio/browserstack-service": "^9.29.1",
    "@wdio/cli": "^8.40.0",
    "@wdio/cucumber-framework": "^9.29.1",
    "@wdio/local-runner": "^9.29.1",
    "@wdio/spec-reporter": "^9.29.1",
    "allure-commandline": "^2.29.0",
    "eslint": "^8.57.0"
  }
}
